# Anthropic API key.
# Required for pydantic-ai routing and Claude model calls.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI API key.
# Optional. Enables OpenAI model calls when configured in main.py.
OPENAI_API_KEY=sk-your-openai-key-here

# Groq API key.
# Optional. Enables Groq model calls when configured in main.py.
GROQ_API_KEY=gsk_your-groq-key-here
