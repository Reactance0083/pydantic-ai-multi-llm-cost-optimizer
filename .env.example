# Anthropic API key (required — used for routing decisions + Claude models)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI API key (optional — enables gpt-4o-mini and gpt-4o routing)
# Find: platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Groq API key (optional — enables ultra-cheap llama routing)
# Find: console.groq.com/keys → Create API key
GROQ_API_KEY=gsk_your-groq-key-here
